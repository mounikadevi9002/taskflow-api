{
  "info": {
    "name": "TaskFlow API",
    "description": "Test collection for TaskFlow REST API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Create Task (Valid)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{ \"text\": \"Buy groceries\" }"
        },
        "url": { "raw": "http://localhost:5000/api/tasks", "host": ["localhost"], "port": "5000", "path": ["api", "tasks"] }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Status is 201', () => pm.response.to.have.status(201));",
            "pm.test('Has id and text', () => {",
            "  const body = pm.response.json();",
            "  pm.expect(body).to.have.property('id');",
            "  pm.expect(body.text).to.eql('Buy groceries');",
            "  pm.expect(body.completed).to.be.false;",
            "  pm.collectionVariables.set('taskId', body.id);",
            "});"
          ]
        }
      }]
    },
    {
      "name": "2. Create Task (Invalid - empty text)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{ \"text\": \"\" }" },
        "url": { "raw": "http://localhost:5000/api/tasks", "host": ["localhost"], "port": "5000", "path": ["api", "tasks"] }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Status is 400', () => pm.response.to.have.status(400));",
            "pm.test('Has error message', () => {",
            "  pm.expect(pm.response.json()).to.have.property('error');",
            "});"
          ]
        }
      }]
    },
    {
      "name": "3. Get All Tasks",
      "request": {
        "method": "GET",
        "url": { "raw": "http://localhost:5000/api/tasks", "host": ["localhost"], "port": "5000", "path": ["api", "tasks"] }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Status is 200', () => pm.response.to.have.status(200));",
            "pm.test('Response is array', () => {",
            "  pm.expect(pm.response.json()).to.be.an('array');",
            "});"
          ]
        }
      }]
    },
    {
      "name": "4. Get Task By ID",
      "request": {
        "method": "GET",
        "url": { "raw": "http://localhost:5000/api/tasks/{{taskId}}", "host": ["localhost"], "port": "5000", "path": ["api", "tasks", "{{taskId}}"] }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Status is 200', () => pm.response.to.have.status(200));",
            "pm.test('Correct task returned', () => {",
            "  const body = pm.response.json();",
            "  pm.expect(body.id).to.eql(pm.collectionVariables.get('taskId'));",
            "});"
          ]
        }
      }]
    },
    {
      "name": "5. Get Task - Not Found",
      "request": {
        "method": "GET",
        "url": { "raw": "http://localhost:5000/api/tasks/9999", "host": ["localhost"], "port": "5000", "path": ["api", "tasks", "9999"] }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Status is 404', () => pm.response.to.have.status(404));"
          ]
        }
      }]
    },
    {
      "name": "6. Update Task",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{ \"text\": \"Buy groceries and milk\", \"completed\": true }" },
        "url": { "raw": "http://localhost:5000/api/tasks/{{taskId}}", "host": ["localhost"], "port": "5000", "path": ["api", "tasks", "{{taskId}}"] }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Status is 200', () => pm.response.to.have.status(200));",
            "pm.test('Task updated', () => {",
            "  const body = pm.response.json();",
            "  pm.expect(body.text).to.eql('Buy groceries and milk');",
            "  pm.expect(body.completed).to.be.true;",
            "});"
          ]
        }
      }]
    },
    {
      "name": "7. Delete Task",
      "request": {
        "method": "DELETE",
        "url": { "raw": "http://localhost:5000/api/tasks/{{taskId}}", "host": ["localhost"], "port": "5000", "path": ["api", "tasks", "{{taskId}}"] }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Status is 204', () => pm.response.to.have.status(204));"
          ]
        }
      }]
    },
    {
      "name": "8. Delete Task - Not Found",
      "request": {
        "method": "DELETE",
        "url": { "raw": "http://localhost:5000/api/tasks/9999", "host": ["localhost"], "port": "5000", "path": ["api", "tasks", "9999"] }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Status is 404', () => pm.response.to.have.status(404));"
          ]
        }
      }]
    }
  ],
  "variable": [{ "key": "taskId", "value": "" }]
}
